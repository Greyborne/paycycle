# Copy to .env and edit before running docker compose.

# REQUIRED in production: random string used to sign session tokens.
# Generate one with:  openssl rand -hex 32
SESSION_SECRET=

# Password for the bundled Postgres container (also used in DATABASE_URL).
POSTGRES_PASSWORD=change-me

# Host port the app is published on.
PAYCYCLE_PORT=8080

# Set to "false" to disable new account sign-ups after you've created yours.
ALLOW_REGISTRATION=true

# Default currency offered during onboarding (any ISO 4217 code).
DEFAULT_CURRENCY=USD

# Timezone used to decide "today" for pay-period boundaries.
TZ=America/New_York

# --- Optional: emailed notifications -----------------------------------
# In-app notifications always work; fill these in to also deliver them by
# email (users opt in under Settings). Leave SMTP_HOST empty to disable.
#APP_URL=https://paycycle.example.com
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASS=
#SMTP_FROM=PayCycle <paycycle@example.com>

# --- Optional: Plaid bank sync -----------------------------------------
# Get keys at https://dashboard.plaid.com (sandbox keys are free). The Bank
# Sync card appears on the Import page once these are set.
#PLAID_CLIENT_ID=
#PLAID_SECRET=
#PLAID_ENV=sandbox
#PLAID_COUNTRY_CODES=US

# --- Optional: OIDC single sign-on ("Sign in with Google" etc.) --------
# Works with any OIDC provider: Google (issuer https://accounts.google.com),
# Keycloak, Authentik, ... Register a client with redirect URI
#   <APP_URL>/api/auth/oidc/callback
# New SSO sign-ins respect ALLOW_REGISTRATION and household invite codes.
# OIDC_ISSUER_INTERNAL: optional backchannel URL when the public issuer
# isn't reachable from inside the container (e.g. Keycloak on this network).
#OIDC_ISSUER=https://accounts.google.com
#OIDC_ISSUER_INTERNAL=
#OIDC_CLIENT_ID=
#OIDC_CLIENT_SECRET=
#OIDC_PROVIDER_NAME=Google
